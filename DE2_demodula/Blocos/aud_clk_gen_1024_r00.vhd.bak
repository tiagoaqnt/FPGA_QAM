-- *************************************************************************************************
-- Bloco: aud_clk_gen_1024_r00
--
----------------------------------------------------------------------------------------------------
-- Descriçăo do programa:
--
-- Este bloco tem as seguintes funcionalidades:
--
-- A partir de 50MHz, gera os diversos clocks necessários aos conversores AD e DA
--
----------------------------------------------------------------------------------------------------
-- ENTRADAS:
--
-- nrst			Reset assíncrono ativo baixo
-- clk_50M		Entrada de clock de 50MHz
-- 
-- 
----------------------------------------------------------------------------------------------------
-- SAIDAS:
--
-- mclk_out		Clock master = 12,500MHz (50MHz / 4)
-- bclk_out		3,125MHz = mclk /4
-- lrck_out		48,828125kHz = bclk / 64
-- nrst_out		saída de reset síncrono com mclk para os demais blocos (ativo baixo)
--
----------------------------------------------------------------------------------------------------
-- ******************************************* REVISŐES ********************************************
----------------------------------------------------------------------------------------------------
-- r00: revisăo inicial
--
-- Desenvolvido por: F. Garcia
-- Validado em: 02/12/2025
----------------------------------------------------------------------------------------------------
-- r01:
--
----------------------------------------------------------------------------------------------------
----------------------------------------------------------------------------------------------------
-- ****************************** Declaraçăo das bibliotecas ***************************************
----------------------------------------------------------------------------------------------------

LIBRARY ieee;
USE ieee.std_logic_1164.all;
use ieee.std_logic_unsigned.all;

----------------------------------------------------------------------------------------------------
-- ****************************************** Entidade *********************************************
----------------------------------------------------------------------------------------------------

ENTITY aud_clk_gen_1024_r00 IS
	PORT
	(
		-- Entradas:
		nrst		: IN STD_LOGIC := '1';	-- reset ativo baixo
		clk_50M		: IN STD_LOGIC;			-- Clock 50MHz
		-- Saídas:
		mclk_out	: OUT STD_LOGIC;		-- 18,432MHz (valor nominal. Tem um erro de -594ppm)
		bclk_out	: OUT STD_LOGIC;		-- 3,072MHz
		lrck_out	: OUT STD_LOGIC;		-- 48,000kHz
		nrst_out	: OUT STD_LOGIC			-- saída de reset (ativo baixo)
	
	);
END entity;

----------------------------------------------------------------------------------------------------
-- ***************************************** Arquitetura *******************************************
----------------------------------------------------------------------------------------------------

ARCHITECTURE arch OF aud_clk_gen_1024_r00 IS
	

	signal clk_cnt		: std_logic_vector(9 downto 0);
	signal nrst_reg		: std_logic;
	
BEGIN

	----------------------------------------------------------------------------
	-- Reset para os outros blocos:
	-- Atrasa de 512 pulsos de clk_50M depois de nrst
	----------------------------------------------------------------------------
	process(nrst, clk_50M, clk_cnt)
	begin
		if nrst = '0' then
			nrst_reg <= '0';
		elsif rising_edge(clk_50M) and clk_cnt(9) = '1' then
			nrst_reg <= '1';
		end if;
	end process;
	
	----------------------------------------------------------------------------
	-- Contador 0 a 1023 incrementado a cada ciclo de clk_50M
	----------------------------------------------------------------------------
	process(nrst, clk_50M)
	begin
		if nrst = '0' then
			clk_cnt <= (others => '0');
		elsif rising_edge(clk_50M) then
			clk_cnt <= clk_cnt + 1;
		end if;
	end process;

	----------------------------------------------------------------------------
	-- Saídas:
	----------------------------------------------------------------------------
	mclk_out <= clk_cnt(2);
	bclk_out <= clk_cnt(4);
	lrck_out <= clk_cnt(9);
	nrst_out <= nrst_reg;

END arch;