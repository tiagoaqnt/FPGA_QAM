library ieee;
use ieee.std_logic_1164.all;
use ieee.numeric_std.all;

entity iir_lpf is
    generic (
		K : integer := 10; 
		G : integer := 4
	);
    port (
        clk, nrst : in std_logic;
        data_in   : in  std_logic_vector(9 downto 0);
        data_out  : out std_logic_vector(9 downto 0)
    );
end entity;

architecture rtl of iir_lpf is
    signal acc1, acc2, acc3, acc4 : signed(K + 10 downto 0) := (others => '0');
    signal s1, s2, s3 : signed(9 downto 0);
begin
    process(clk, nrst)
    begin
        if nrst = '0' then
            acc1 <= (others => '0'); acc2 <= (others => '0');
            acc3 <= (others => '0'); acc4 <= (others => '0');
        elsif rising_edge(clk) then
            acc1 <= acc1 + resize(signed(data_in) * G, K + 11) - shift_right(acc1, K);
            s1   <= acc1(K + 9 downto K);
            acc2 <= acc2 + resize(s1, K + 11) - shift_right(acc2, K);
            s2   <= acc2(K + 9 downto K);
            acc3 <= acc3 + resize(s2, K + 11) - shift_right(acc3, K);
            s3   <= acc3(K + 9 downto K);
            acc4 <= acc4 + resize(s3, K + 11) - shift_right(acc4, K);
        end if;
    end process;
    data_out <= std_logic_vector(acc4(K + 9 downto K));
end rtl;